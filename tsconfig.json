{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "resolveJsonModule": true,

    "paths": {
      "@taskforge-ai/mcp-server": ["./apps/mcp-server/src"],
      "@taskforge-ai/worker": ["./apps/worker/src"],
      "@taskforge-ai/agent-core": ["./packages/agent-core/src"],
      "@taskforge-ai/jira-client": ["./packages/jira-client/src"],
      "@taskforge-ai/github-client": ["./packages/github-client/src"],
      "@taskforge-ai/shared": ["./packages/shared/src"]
    },

    "strict": true,
    "skipLibCheck": true
  },

  "exclude": ["node_modules", "dist"]
}