{
  "name": "taskforge-ai",
  "version": "0.1.0",
  "description": "Monorepo for Taskforge — an AI agent that reads Jira tickets, writes the implementation, and opens a GitHub PR with human approval at every step.",
  "author": "Tomasz Czechowski <tomasz@czechowski.pl>",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev:worker": "tsx apps/worker/src/index.ts",
    "dev:mcp": "tsx apps/mcp-server/src/index.ts",
    "dev:cli": "pnpm --filter @taskforge-ai/cli dev",
    "build": "pnpm -r run build",
    "build:cli": "pnpm --filter @taskforge-ai/cli build",
    "start:worker": "pnpm --filter @taskforge-ai/worker start",
    "start:mcp": "pnpm --filter @taskforge-ai/mcp-server start",
    "publish": "pnpm --filter \"@taskforge-ai/*\" publish",
    "format": "prettier --write \"apps/**/*.ts\" \"packages/**/*.ts\"",
    "format:check": "prettier --check \"apps/**/*.ts\" \"packages/**/*.ts\"",
    "lint": "eslint \"apps/**/*.ts\" \"packages/**/*.ts\"",
    "lint:fix": "eslint --fix \"apps/**/*.ts\" \"packages/**/*.ts\""
  },
  "dependencies": {
    "@octokit/core": "^7.0.6",
    "@octokit/plugin-rest-endpoint-methods": "^17.0.0",
    "axios": "^1.6.0",
    "body-parser": "^1.20.2",
    "express": "^4.18.2",
    "octokit": "^3.1.0",
    "pg": "^8.20.0",
    "pgvector": "^0.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^4.17.21",
    "@types/node": "^25.6.0",
    "env-cmd": "^11.0.0",
    "eslint": "^10.2.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.2"
  }
}
